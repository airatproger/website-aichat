{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/extension/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|accent|solid|danger)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'accent' | 'solid' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|fullWidth|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, fullWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|danger|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'danger' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm|xs)$/]",
        "message": "<Button> size must be one of 'md' | 'sm' | 'xs'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:frosted|radius|padding|elevated|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: frosted, radius, padding, elevated."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: role."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:user|assistant)$/]",
        "message": "<ChatBubble> role must be one of 'user' | 'assistant'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|selected|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: label, icon, selected."
      },
      {
        "selector": "JSXOpeningElement[name.name='Composer'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|onSend|placeholder|showAttach|showWaveform|mode|leftSlot|key|ref|className|style|children)$/]",
        "message": "<Composer> doesn't accept that prop. Declared props: value, onChange, onSend, placeholder, showAttach, showWaveform, mode, leftSlot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Composer'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:mic|send)$/]",
        "message": "<Composer> mode must be one of 'mic' | 'send'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hint'] > JSXAttribute > JSXIdentifier[name!=/^(?:placement|maxWidth|key|ref|className|style|children)$/]",
        "message": "<Hint> doesn't accept that prop. Declared props: placement, maxWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hint'] > JSXAttribute[name.name='placement'] > Literal[value!=/^(?:top|bottom)$/]",
        "message": "<Hint> placement must be one of 'top' | 'bottom'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|iconSize|active|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, variant, size, iconSize, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|glass|accent|voice)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'glass' | 'accent' | 'voice'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MenuRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|leadingIcon|sublabel|value|trailing|selected|showChevron|destructive|key|ref|className|style|children)$/]",
        "message": "<MenuRow> doesn't accept that prop. Declared props: label, leadingIcon, sublabel, value, trailing, selected, showChevron, destructive."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|sublabel|icon|selected|key|ref|className|style|children)$/]",
        "message": "<ModelRow> doesn't accept that prop. Declared props: name, sublabel, icon, selected."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:frosted|interactive|padding|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: frosted, interactive, padding."
      },
      {
        "selector": "JSXOpeningElement[name.name='RateStars'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|label|onRate|onDismiss|size|key|ref|className|style|children)$/]",
        "message": "<RateStars> doesn't accept that prop. Declared props: value, max, label, onRate, onDismiss, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|title|subtitle|onClose|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: status, title, subtitle, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:success|error|info)$/]",
        "message": "<Toast> status must be one of 'success' | 'error' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: checked, onChange, disabled, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
